# ─────────────────────────────────────────────────────────────
# legal-ai-assistant/.env.example
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── LLM ───────────────────────────────────────────────────────
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# auto = Gemini first, fallback to Phi-3
# gemini = always use Gemini
# phi3   = always use local Phi-3
LLM_MODE=auto

# ── Vector DB ─────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Elasticsearch ─────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Ollama (Phi-3 local LLM) ──────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ── Voice / Whisper ───────────────────────────────────────────
# tiny | base | small | medium | large
# small = best balance of speed + accuracy for Indian languages
WHISPER_MODEL=small
TTS_OUTPUT_DIR=/tmp/tts_audio

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=/tmp/uploads

# ── API Security (optional) ───────────────────────────────────
API_KEY_REQUIRED=false
API_KEY=legal-ai-dev-key

# ── App ───────────────────────────────────────────────────────
DEBUG=true